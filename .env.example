# ── PostgreSQL (local Docker dev) ──────────────────────────────────
# These are used by docker-compose.yml for the local Postgres service.
# In production, use a Coolify-managed PostgreSQL resource instead.

POSTGRES_USER=parkquest
POSTGRES_PASSWORD=changeme
POSTGRES_DB=parkquest
POSTGRES_PORT=5432

# ── Database URL ───────────────────────────────────────────────────
# Local (non-Docker) dev: postgresql://parkquest:changeme@localhost:5432/parkquest
# Docker dev (via compose): auto-wired from POSTGRES_* vars above
# Production (Coolify): use the Coolify PostgreSQL Internal Database URL
#   e.g. postgresql://user:password@parkquest-db:5432/parkquest
DATABASE_URL=postgresql://parkquest:changeme@localhost:5432/parkquest

# ── Better Auth ────────────────────────────────────────────────────
# Generate a strong secret:
#   openssl rand -base64 48
# Keep this stable across deployments — changing it invalidates all sessions.
BETTER_AUTH_SECRET=

# Must match the deployed domain exactly. Examples:
#   Development: http://localhost:3000
#   Production:  https://parkquest.club
BETTER_AUTH_URL=http://localhost:3000
