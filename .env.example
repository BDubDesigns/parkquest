# PostgreSQL credentials used by the postgres service in docker-compose.
POSTGRES_USER=parkquest
POSTGRES_PASSWORD=changeme
POSTGRES_DB=parkquest
POSTGRES_PORT=5432

# Connection string the app uses to reach Postgres. The Docker compose setup
# wires this automatically from the POSTGRES_* vars above for the app container.
# For local (non-Docker) dev, set this to your local Postgres instance:
DATABASE_URL=postgresql://parkquest:changeme@localhost:5432/parkquest
